---
/**
 * Installer router. The middleware funnels every non-installer request to
 * `/install` until setup is complete; this page just decides which step
 * the operator should see based on the current state and 302s there.
 *
 * Kept as its own page (rather than inlining the redirect logic into
 * `/install/database.astro`) so a bookmarked `/install` always lands the
 * operator on the right step after a refresh.
 */
import { getInstallState } from '../../lib/install.ts';

const state = await getInstallState();

if (state === 'no-db-config') return Astro.redirect('/install/database');
if (state === 'no-tables' || state === 'no-admin') return Astro.redirect('/install/site');

// `'installed'` is handled in middleware (returns 404 for /install/*), but
// guard here too in case a future change relaxes that gate.
return Astro.redirect('/admin');
---
