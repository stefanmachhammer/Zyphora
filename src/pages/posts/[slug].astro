---
/**
 * Single-post route. Looks up the post by slug (published only — drafts are
 * never publicly visible) and renders via the active theme's `post.eta`.
 *
 * 404s render through the theme too so the look stays consistent on miss.
 *
 * Comments: this route also handles guest comment submissions. POSTs validate
 * via `commentFormSchema`, insert through `createComment` (which strips HTML
 * and lands the row as `pending`), then redirect with `?comment=pending#comments`
 * so a refresh doesn't re-submit. On validation failure we re-render the same
 * page with the user's previous values + per-field errors via `commentForm`
 * in the render context.
 */
import { db, schema } from '../../db/client.ts';
import { eq, and } from 'drizzle-orm';
import { renderTheme } from '../../lib/themes/render.ts';
import { commentFormSchema, createComment, getApprovedComments } from '../../lib/comments.ts';
import { getSetting } from '../../lib/settings.ts';
import type { CommentFormState } from '../../lib/themes/types.ts';

const { slug } = Astro.params;
if (!slug) {
  return await renderTheme({ template: 'notFound', pathname: Astro.url.pathname, status: 404 });
}

// Fetch the post first — we need its id to attach a comment to, and we want
// to 404 the same way regardless of GET or POST.
const row = await db
  .select({
    id: schema.posts.id,
    slug: schema.posts.slug,
    title: schema.posts.title,
    excerpt: schema.posts.excerpt,
    contentHtml: schema.posts.contentHtml,
    publishedAt: schema.posts.publishedAt,
    commentsEnabled: schema.posts.commentsEnabled,
    moderateComments: schema.posts.moderateComments,
    authorName: schema.users.displayName,
  })
  .from(schema.posts)
  .leftJoin(schema.users, eq(schema.users.id, schema.posts.authorId))
  .where(and(eq(schema.posts.slug, slug), eq(schema.posts.status, 'published')))
  .get();

if (!row) {
  return await renderTheme({ template: 'notFound', pathname: Astro.url.pathname, status: 404 });
}

let commentForm: CommentFormState | undefined;

// Hard-stop any comment submission when the author has disabled comments on
// this post. The form is hidden in the template too, but a stale tab (or a
// scripted POST) shouldn't be able to bypass the toggle.
if (Astro.request.method === 'POST' && !row.commentsEnabled) {
  return new Response('Comments are disabled for this post.', {
    status: 403,
    headers: { 'content-type': 'text/plain' },
  });
}

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const raw = {
    postId: row.id,
    authorName: String(form.get('authorName') ?? ''),
    authorEmail: String(form.get('authorEmail') ?? ''),
    authorUrl: String(form.get('authorUrl') ?? ''),
    content: String(form.get('content') ?? ''),
  };
  const parsed = commentFormSchema.safeParse(raw);
  if (parsed.success) {
    // Resolve the effective moderation policy: the per-post override wins
    // when set, otherwise fall back to the site-wide setting (default on).
    const siteRequiresModeration = (await getSetting('require_comment_moderation', '1')) === '1';
    const moderate = row.moderateComments ?? siteRequiresModeration;
    const { status } = await createComment(parsed.data, {
      ipAddress: Astro.clientAddress,
      userAgent: Astro.request.headers.get('user-agent') ?? undefined,
      initialStatus: moderate ? 'pending' : 'approved',
    });
    // Redirect after successful POST so a refresh doesn't double-submit.
    // Banner text branches on whether the comment was auto-approved.
    return Astro.redirect(`/posts/${row.slug}?comment=${status}#comments`);
  }

  // Re-render the page with the user's previous values and a field-keyed
  // error map so the template can highlight the offending fields.
  const errors: Record<string, string> = {};
  for (const issue of parsed.error.issues) {
    const key = String(issue.path[0] ?? '_');
    if (!errors[key]) errors[key] = issue.message;
  }
  commentForm = {
    values: {
      authorName: raw.authorName,
      authorEmail: raw.authorEmail,
      authorUrl: raw.authorUrl,
      content: raw.content,
    },
    errors,
  };
}

// Skip the fetch entirely when comments are disabled — disabling hides both
// the form and any previously approved comments, so there's nothing to render.
const comments = row.commentsEnabled ? await getApprovedComments(row.id) : [];
// The post-submit redirect carries the final status so the template can pick
// between "thanks, your comment is up" and "thanks, awaiting moderation."
const commentSubmittedParam = Astro.url.searchParams.get('comment');
const commentSubmitted: 'pending' | 'approved' | null =
  commentSubmittedParam === 'pending' || commentSubmittedParam === 'approved' ? commentSubmittedParam : null;

const escapeHtml = (s: string) =>
  s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
const formatComment = (s: string) => escapeHtml(s).replace(/\r?\n/g, '<br>');

// Strip the internal `id` from the post payload exposed to the template —
// theme templates don't need it and shouldn't grow a dependency on it.
const { id: _postId, ...publicPost } = row;

return await renderTheme({
  template: 'post',
  pathname: Astro.url.pathname,
  post: publicPost,
  comments: comments.map((c) => ({
    id: c.id,
    authorName: c.authorName,
    authorUrl: c.authorUrl,
    content: c.content,
    contentHtml: formatComment(c.content),
    createdAt: c.createdAt,
  })),
  commentForm,
  commentSubmitted,
  status: commentForm ? 400 : 200,
});
---