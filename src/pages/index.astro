---
/**
 * Homepage — list of published posts.
 *
 * This route is intentionally thin: fetch the data, hand it to the theme
 * renderer, and return whatever Response the active theme produces. The
 * markup lives entirely in the theme's `index.eta` template.
 */
import { db, schema } from '../db/client.ts';
import { eq, desc } from 'drizzle-orm';
import { renderTheme } from '../lib/themes/render.ts';

const posts = await db
  .select({
    slug: schema.posts.slug,
    title: schema.posts.title,
    excerpt: schema.posts.excerpt,
    publishedAt: schema.posts.publishedAt,
    authorName: schema.users.displayName,
    category: schema.posts.category,
  })
  .from(schema.posts)
  .leftJoin(schema.users, eq(schema.users.id, schema.posts.authorId))
  .where(eq(schema.posts.status, 'published'))
  .orderBy(desc(schema.posts.publishedAt))
  .all();

return await renderTheme({
  template: 'index',
  pathname: Astro.url.pathname,
  posts,
  currentUser: Astro.locals.user,
});
---