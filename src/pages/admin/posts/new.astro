---
/**
 * New-post form.
 *
 * On a validation error we re-render with the user's typed values restored,
 * so they don't lose their work. On success we redirect to the edit page
 * (PRG pattern, with `?created=1` so the edit page can show a success banner).
 */
import AdminLayout from '../../../layouts/AdminLayout.astro';
import TiptapEditor from '../../../components/TiptapEditor.tsx';
import { postFormSchema, createPost } from '../../../lib/posts.ts';

let error: string | null = null;
// Form-side representation of the tri-state moderation override. The DB stores
// null/true/false; the form posts these strings so a stale form roundtrip
// can't lose the distinction between "inherit" and "off."
type ModerationChoice = 'default' | 'require' | 'auto';
const moderationChoiceFromForm = (v: FormDataEntryValue | null): ModerationChoice => {
  const s = String(v ?? 'default');
  return s === 'require' || s === 'auto' ? s : 'default';
};
const moderationChoiceToValue = (c: ModerationChoice): boolean | null => (c === 'default' ? null : c === 'require');
let values: { title: string; slug: string; excerpt: string; contentHtml: string; status: 'draft' | 'published'; category: 'news' | 'travel' | 'gadgets' | 'reviews'; commentsEnabled: boolean; moderation: ModerationChoice } = {
  title: '', slug: '', excerpt: '', contentHtml: '', status: 'draft', category: 'news', commentsEnabled: true, moderation: 'default',
};

if (Astro.request.method === 'POST') {
  // Run the form through the shared zod schema (also used by the edit page)
  // so validation rules and error messages stay consistent.
  const form = await Astro.request.formData();
  // Unchecked checkboxes don't appear in form data at all, so presence ==
  // checked. Translate to a real boolean before validation.
  const commentsEnabled = form.get('commentsEnabled') !== null;
  const moderationChoice = moderationChoiceFromForm(form.get('moderation'));
  const parsed = postFormSchema.safeParse({
    title: form.get('title') ?? '',
    slug: form.get('slug') ?? '',
    excerpt: form.get('excerpt') ?? '',
    contentHtml: form.get('contentHtml') ?? '',
    status: form.get('status') ?? 'draft',
    category: form.get('category') ?? 'news',
    commentsEnabled,
    moderateComments: moderationChoiceToValue(moderationChoice),
  });

  if (!parsed.success) {
    // Keep the raw form values around so re-rendering the page restores
    // what the user typed instead of clearing the form on error.
    error = parsed.error.issues[0]?.message ?? 'Invalid input';
    const rawCategory = String(form.get('category') ?? 'news');
    values = {
      title: String(form.get('title') ?? ''),
      slug: String(form.get('slug') ?? ''),
      excerpt: String(form.get('excerpt') ?? ''),
      contentHtml: String(form.get('contentHtml') ?? ''),
      status: form.get('status') === 'published' ? 'published' : 'draft',
      category: (['news', 'travel', 'gadgets', 'reviews'].includes(rawCategory) ? rawCategory : 'news') as 'news' | 'travel' | 'gadgets' | 'reviews',
      commentsEnabled,
      moderation: moderationChoice,
    };
  } else {
    // Insert + redirect (PRG). The edit page picks up `?created=1` and
    // surfaces a success banner.
    const newId = await createPost(parsed.data, Astro.locals.user!.id);
    return Astro.redirect(`/admin/posts/${newId}?created=1`);
  }
}
---
<AdminLayout title="New post">
  <div class="toolbar">
    <h1 style="margin:0">New post</h1>
    <a href="/admin/posts" class="btn secondary">← Back</a>
  </div>

  {error && <div class="alert error">{error}</div>}

  <form method="POST">
    <div class="card" style="margin-bottom:16px">
      <div class="field">
        <label for="title">Title</label>
        <input class="input" id="title" name="title" required value={values.title} />
      </div>
      <div class="field">
        <label for="slug">Slug (optional — auto-generated)</label>
        <input class="input" id="slug" name="slug" value={values.slug} placeholder="my-first-post" />
      </div>
      <div class="field">
        <label for="excerpt">Excerpt</label>
        <textarea class="textarea" id="excerpt" name="excerpt" rows="2">{values.excerpt}</textarea>
      </div>
      <div class="field">
        <label>Content</label>
        <TiptapEditor name="contentHtml" initialHtml={values.contentHtml} client:only="react" />
      </div>
      <div class="field">
        <label for="status">Status</label>
        <select class="select" id="status" name="status">
          <option value="draft" selected={values.status === 'draft'}>Draft</option>
          <option value="published" selected={values.status === 'published'}>Published</option>
        </select>
      </div>
      <div class="field">
        <label for="category">Category</label>
        <select class="select" id="category" name="category">
          <option value="news" selected={values.category === 'news'}>News</option>
          <option value="travel" selected={values.category === 'travel'}>Travel</option>
          <option value="gadgets" selected={values.category === 'gadgets'}>Gadgets</option>
          <option value="reviews" selected={values.category === 'reviews'}>Reviews</option>
        </select>
      </div>
      <div class="field">
        <label style="display:inline-flex;align-items:center;gap:8px;cursor:pointer">
          <input type="checkbox" name="commentsEnabled" checked={values.commentsEnabled} />
          <span>Allow comments on this post</span>
        </label>
      </div>
      <div class="field">
        <label for="moderation">Comment moderation</label>
        <select class="select" id="moderation" name="moderation">
          <option value="default" selected={values.moderation === 'default'}>Use site default</option>
          <option value="require" selected={values.moderation === 'require'}>Hold for moderation</option>
          <option value="auto" selected={values.moderation === 'auto'}>Auto-approve</option>
        </select>
      </div>
    </div>
    <button type="submit" class="btn">Create post</button>
  </form>
</AdminLayout>