
---
/**
 * Admin shell — sidebar + main content slot. Wraps every page under `/admin`.
 *
 * The sidebar toggles between "full" and "rail" modes; the choice persists in
 * a non-HTTP cookie (`zyphora_sidebar`) so the rendered HTML matches the
 * user's last preference on first paint and there's no flash of width change.
 *
 * The "Users" link is admin-only — middleware blocks the underlying page for
 * non-admins anyway, but hiding the link keeps the UI honest.
 */
import '../styles/admin.css';
const { user } = Astro.locals;
const { title = 'Admin' } = Astro.props as { title?: string };
const path = Astro.url.pathname;
const isActive = (p: string) => path === p || path.startsWith(p + '/');
const sidebarMode = Astro.cookies.get('zyphora_sidebar')?.value === 'rail' ? 'rail' : 'full';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title} · Zyphora</title>
  </head>
  <body class="admin" data-sidebar={sidebarMode}>
    <aside class="sidebar">
      <div class="brand">
        <img src="/logo.png" alt="Zyphora" class="brand-logo" />
        <img src="/favicon.png" alt="Zyphora" class="brand-mark" />
      </div>
      <nav>
        <a href="/admin" class={isActive('/admin') && path === '/admin' ? 'active' : ''} title="Dashboard">
          <svg class="nav-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12l9-9 9 9"/><path d="M5 10v10h14V10"/></svg>
          <span class="nav-label">Dashboard</span>
        </a>
        <a href="/admin/posts" class={isActive('/admin/posts') ? 'active' : ''} title="Posts">
          <svg class="nav-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h12l4 4v12H4z"/><path d="M16 4v4h4"/><path d="M8 12h8M8 16h8M8 8h4"/></svg>
          <span class="nav-label">Posts</span>
        </a>
        <a href="/admin/media" class={isActive('/admin/media') ? 'active' : ''} title="Media">
          <svg class="nav-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"/><circle cx="9" cy="10" r="2"/><path d="M21 16l-5-5-9 9"/></svg>
          <span class="nav-label">Media</span>
        </a>
        <a href="/admin/themes" class={isActive('/admin/themes') ? 'active' : ''} title="Themes">
          <svg class="nav-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="10.5" r="2.5"/><circle cx="8.5" cy="7.5" r="2.5"/><circle cx="6.5" cy="12.5" r="2.5"/><path d="M12 22a10 10 0 1 1 10-10c0 2.5-3 2-3 4s2 6-7 6z"/></svg>
          <span class="nav-label">Themes</span>
        </a>
        {user?.role === 'admin' && (
          <a href="/admin/users" class={isActive('/admin/users') ? 'active' : ''} title="Users">
            <svg class="nav-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3.5"/><path d="M3 20c0-3.3 2.7-6 6-6s6 2.7 6 6"/><circle cx="17" cy="9" r="2.5"/><path d="M15 20c0-2.5 2-4.5 4.5-4.5"/></svg>
            <span class="nav-label">Users</span>
          </a>
        )}
        <a href="/admin/settings" class={isActive('/admin/settings') ? 'active' : ''} title="Settings">
          <svg class="nav-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.7 1.7 0 0 0 .3 1.8l.1.1a2 2 0 1 1-2.8 2.8l-.1-.1a1.7 1.7 0 0 0-1.8-.3 1.7 1.7 0 0 0-1 1.5V21a2 2 0 1 1-4 0v-.1a1.7 1.7 0 0 0-1.1-1.5 1.7 1.7 0 0 0-1.8.3l-.1.1a2 2 0 1 1-2.8-2.8l.1-.1a1.7 1.7 0 0 0 .3-1.8 1.7 1.7 0 0 0-1.5-1H3a2 2 0 1 1 0-4h.1a1.7 1.7 0 0 0 1.5-1.1 1.7 1.7 0 0 0-.3-1.8l-.1-.1a2 2 0 1 1 2.8-2.8l.1.1a1.7 1.7 0 0 0 1.8.3H9a1.7 1.7 0 0 0 1-1.5V3a2 2 0 1 1 4 0v.1a1.7 1.7 0 0 0 1 1.5 1.7 1.7 0 0 0 1.8-.3l.1-.1a2 2 0 1 1 2.8 2.8l-.1.1a1.7 1.7 0 0 0-.3 1.8V9a1.7 1.7 0 0 0 1.5 1H21a2 2 0 1 1 0 4h-.1a1.7 1.7 0 0 0-1.5 1z"/></svg>
          <span class="nav-label">Settings</span>
        </a>
        <a href="/" target="_blank" rel="noopener" title="View site">
          <svg class="nav-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><path d="M12 3a14 14 0 0 1 0 18"/><path d="M12 3a14 14 0 0 0 0 18"/></svg>
          <span class="nav-label">View site</span>
        </a>
      </nav>
      <div class="user-block">
        <div class="user-info">
          <div class="user-avatar">{user?.displayName?.[0]?.toUpperCase() ?? '?'}</div>
          <div class="user-text">
            <div class="user-name">{user?.displayName}</div>
            <div class="user-role">{user?.role}</div>
          </div>
        </div>
        <form method="POST" action="/admin/logout">
          <button type="submit" class="logout" title="Log out">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><path d="M16 17l5-5-5-5"/><path d="M21 12H9"/></svg>
            <span class="nav-label">Log out</span>
          </button>
        </form>
      </div>
      <button id="sidebar-toggle" type="button" class="sidebar-toggle" aria-label="Toggle sidebar">
        <svg class="sidebar-toggle-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 6l-6 6 6 6"/>
        </svg>
      </button>
    </aside>
    <main class="content">
      <slot />
    </main>
    <script is:inline>
      // Sidebar toggle. Inlined (not a React island) because it touches a
      // single class+cookie and we want it ready before any hydration runs —
      // otherwise toggling would briefly flicker. The cookie is read by the
      // server on next render so the chosen mode survives reloads.
      (() => {
        const btn = document.getElementById('sidebar-toggle');
        if (!btn) return;
        btn.addEventListener('click', () => {
          const next = document.body.dataset.sidebar === 'rail' ? 'full' : 'rail';
          document.body.dataset.sidebar = next;
          document.cookie = `zyphora_sidebar=${next}; path=/; max-age=${60 * 60 * 24 * 365}; samesite=lax`;
        });
      })();
    </script>
  </body>
</html>